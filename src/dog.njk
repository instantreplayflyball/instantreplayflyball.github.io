---
pagination:
  data: team.members
  size: 1
  alias: member
permalink: "dogs/{{ member | dogSlug }}/index.html"
---

<div class="page-title">
  <div class="page-title__inner">
    <p class="section__lead" style="margin-bottom:var(--space-sm);"><a href="/athletes.html">← All athletes</a></p>
    <h1>{{ member.dog }}</h1>
    {% if member.handler | trim %}
    <p>{{ member.handler }}</p>
    {% endif %}
  </div>
</div>

<main id="main">
  <section class="section section--tight">
    <div class="section__inner" style="max-width:40rem">
      <article class="team-card team-card--profile">
        <div class="team-card__photo">
          {% set photo = member.photo | trim %}
          {% if photo %}
          <img src="/{{ photo }}" alt="{{ member.photoAlt | default(member.dog + ' photo') }}" loading="eager" decoding="async">
          {% else %}
          Add photo
          {% endif %}
        </div>
        <div class="team-card__body">
          {% if member.breed | trim %}
          <p class="team-card__breed">{{ member.breed }}</p>
          {% endif %}
          {% for line in member.bio | bioLines %}
          <p>{{ line }}</p>
          {% endfor %}
        </div>
      </article>
    </div>
  </section>
</main>
