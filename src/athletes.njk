---
layout: layout.njk
title: Athletes | Instant Replay Flyball
description: Handlers and dogs on the Instant Replay Flyball team.
current: athletes
permalink: athletes.html
---

<div class="page-title">
  <div class="page-title__inner">
    <h1>Athletes</h1>
    <p>Meet members of Instant Replay and their four-legged teammates. Tap a name or photo to open a dog’s profile page.</p>
  </div>
</div>

<main id="main">
  <section class="section section--tight">
    <div class="section__inner">
      {% set members = team.members | sortTeamMembers(team.rosterSort) %}
      {% if members | length %}
      <div class="team-grid" aria-live="polite">
        {% for m in members %}
        <article class="team-card">
          <div class="team-card__photo">
            {% set photo = m.photo | trim %}
            {% if photo %}
            <a href="/dogs/{{ m | dogSlug }}/" class="team-card__photo-link" aria-label="Profile: {{ m.dog }}">
              <img src="/{{ photo }}" alt="{{ m.photoAlt | default(m.dog + ' photo') }}" loading="lazy" decoding="async">
            </a>
            {% else %}
            Photo coming soon
            {% endif %}
          </div>
          <div class="team-card__body">
            <h3><a href="/dogs/{{ m | dogSlug }}/">{{ m.dog }}</a></h3>
            {% if m.breed | trim %}
            <p class="team-card__breed">{{ m.breed }}</p>
            {% endif %}
            {% for line in m.bio | bioLines %}
            <p>{{ line }}</p>
            {% endfor %}
            {% if m.handler | trim %}
            <p class="team-card__meta">{{ m.handler }}</p>
            {% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
      {% else %}
      <p class="team-empty">Roster coming soon.</p>
      {% endif %}
    </div>
  </section>
</main>
